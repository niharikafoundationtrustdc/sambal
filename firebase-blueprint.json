{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user role and basic profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { 
          "type": "string", 
          "enum": ["Super_Admin", "admin", "Expert", "Researcher", "Intern", "STUDENT", "User"] 
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "SAMBALRecord": {
      "title": "SAMBAL M5 Ledger Record",
      "description": "A form submission record in the M5 Master Ledger.",
      "type": "object",
      "properties": {
        "uin": { "type": "string", "description": "Unique Identification Number" },
        "branchId": { "type": "string" },
        "formId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { 
          "type": "string", 
          "enum": ["Pending", "Approved", "Rejected", "More Info Required"] 
        },
        "data": { "type": "object", "description": "The raw form data payload" },
        "decisionOfficerUin": { "type": "string" },
        "decisionTimestamp": { "type": "string", "format": "date-time" },
        "adminRemarks": { "type": "string" }
      },
      "required": ["uin", "formId", "timestamp", "status", "data"]
    },
    "WishItem": {
      "title": "Digital Wish-Tree Item",
      "description": "An urgent need item for the M7 Wish-Tree.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "urgency": { "type": "string", "enum": ["Urgent", "Normal"] },
        "status": { "type": "string", "enum": ["Available", "Pending", "Fulfilled"] },
        "fulfilledBy": { "type": "string", "description": "UID of the donor" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "category", "urgency", "status"]
    },
    "ImpactStat": {
      "title": "Impact Pulse Statistic",
      "description": "Aggregated impact metrics for the live ticker.",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "number" },
        "label": { "type": "string" }
      },
      "required": ["key", "value", "label"]
    },
    "VolunteerTask": {
      "title": "M11 Volunteer Task",
      "description": "A task assigned to a volunteer or intern.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["Online", "Offline"] },
        "requiredSkill": { "type": "string" },
        "language": { "type": "string" },
        "targetPincode": { "type": "string" },
        "deadline": { "type": "string", "format": "date-time" },
        "assignedTo": { "type": "string", "description": "UID of the volunteer" },
        "status": { "type": "string", "enum": ["Open", "Assigned", "Completed", "Verified"] },
        "sroiValue": { "type": "number" }
      },
      "required": ["title", "type", "status"]
    },
    "WorkLog": {
      "title": "M11 Proof of Work Log",
      "description": "Daily activity log submitted by volunteers.",
      "type": "object",
      "properties": {
        "volunteerId": { "type": "string" },
        "taskId": { "type": "string" },
        "hours": { "type": "number" },
        "mood": { "type": "string", "enum": ["Calm", "Fatigued", "Severe Stress"] },
        "proofUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Verified", "Rejected"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["volunteerId", "hours", "mood", "status"]
    },
    "CampaignSubmission": {
      "title": "M12 Campaign Content",
      "description": "Content submitted for campaigns.",
      "type": "object",
      "properties": {
        "submitterId": { "type": "string" },
        "title": { "type": "string" },
        "contentType": { "type": "string" },
        "language": { "type": "string" },
        "targetAudience": { "type": "string" },
        "assetUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["Quarantine", "Approved", "Published"] }
      },
      "required": ["title", "contentType", "status"]
    },
    "EventRSVP": {
      "title": "M12 Event RSVP",
      "description": "RSVP for physical events.",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "isGovtOrPress": { "type": "boolean" },
        "attendees": { "type": "number" }
      },
      "required": ["name", "email", "isGovtOrPress"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/records/{recordId}": {
      "schema": "SAMBALRecord",
      "description": "M5 Ledger form submissions"
    },
    "/wishes/{wishId}": {
      "schema": "WishItem",
      "description": "M7 Wish-Tree items"
    },
    "/stats/{statId}": {
      "schema": "ImpactStat",
      "description": "Aggregated impact statistics"
    },
    "/tasks/{taskId}": {
      "schema": "VolunteerTask",
      "description": "M11 Volunteer tasks"
    },
    "/work_logs/{logId}": {
      "schema": "WorkLog",
      "description": "M11 Proof of work logs"
    },
    "/campaigns/{campaignId}": {
      "schema": "CampaignSubmission",
      "description": "M12 Campaign content"
    },
    "/rsvps/{rsvpId}": {
      "schema": "EventRSVP",
      "description": "M12 Event RSVPs"
    }
  }
}
